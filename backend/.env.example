# ── AURORA Environment Variables ─────────────────────────────

# App
APP_NAME=AURORA
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://aurora:aurora_pass@localhost:5432/aurora_db
DATABASE_ECHO=false

# CORS
CORS_ORIGINS=http://localhost:3000

# ML Models
ENERGY_MODEL_PATH=models/energy_model.pt
BURNOUT_MODEL_PATH=models/burnout_model.joblib
RL_MODEL_PATH=models/rl_agent.pt

# Identity Engine
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# RL Scheduler
RL_LEARNING_RATE=0.001
RL_GAMMA=0.99
RL_EPSILON_START=1.0
RL_EPSILON_END=0.01
RL_EPSILON_DECAY=1000
RL_BATCH_SIZE=64
RL_MEMORY_SIZE=10000

# Replanning Thresholds
ENERGY_DEVIATION_THRESHOLD=2.0
STRESS_SPIKE_THRESHOLD=0.8
